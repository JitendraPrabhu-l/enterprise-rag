# Copy to .env and fill in. GROQ_API_KEY is required to run the stack locally —
# every other dependency (Qdrant, OpenSearch, Neo4j) is self-hosted via
# docker-compose. Every LLM call in the stack (generation, vision, query
# expansion/HyDE, GraphRAG extraction, RAG Triad judging) runs on Groq —
# https://console.groq.com/keys
GROQ_API_KEY=

# Overrides — defaults below match docker-compose service names/ports.
# openai/gpt-oss-120b supports both text and vision, so one model covers
# every role; override individually if a task benefits from a different model.
GENERATION_MODEL=openai/gpt-oss-120b
VISION_MODEL=openai/gpt-oss-120b
UTILITY_MODEL=openai/gpt-oss-120b

QDRANT_URL=http://qdrant:6333
OPENSEARCH_URL=http://opensearch:9200
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-in-prod

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_TRACES_SAMPLE_RATE=1.0

ENVIRONMENT=development
LOG_LEVEL=INFO

# --- ADR-023: contextual retrieval enrichment (ingestion) ---
# One utility-model call per chunk to situate it before indexing. On by
# default; set false for the fastest/cheapest possible ingest.
CONTEXTUAL_ENRICHMENT_ENABLED=true
CONTEXTUAL_ENRICHMENT_CONCURRENCY=8

# --- ADR-026: semantic answer cache (generation) ---
# A query >= this cosine-similar to one already answered, within the SAME
# tenant/principal/domain scope, returns the cached answer — skipping
# retrieval + generation entirely. Guardrail-flagged answers are never cached.
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95
SEMANTIC_CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- ADR-029: ColPali visual retrieval (ingestion, opt-in) ---
# Off by default: colpali-engine's model backbone is a multi-GB download and
# CPU inference is slow — this is a deliberate deployment decision, not a
# default every ingest should pay for. Requires
# `pip install rag-ingestion[colpali]` when enabled.
COLPALI_ENABLED=false
COLPALI_MODEL_NAME=vidore/colpali-v1.3
